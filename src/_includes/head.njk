{%- set pageTitle = title or site.name -%}
{%- set pageDescription = description or summary or seo.defaultDescription -%}
{%- set canonicalUrl = site.baseUrl + (page.url | default('/')) -%}
{%- set ogImage = ogImage or seo.defaultOgImage -%}
{%- if ogImage.startsWith('http') -%}
  {%- set ogImageUrl = ogImage -%}
{%- else -%}
  {%- set ogImageUrl = site.baseUrl + ogImage -%}
{%- endif -%}
{%- set ogType = ogType or ((schemaType == 'BlogPosting' or schemaType == 'ScholarlyArticle') and 'article' or 'website') -%}
{%- set metaRobots = metaRobots or 'index, follow' -%}
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ pageTitle }}{% if page.url != '/' %} | {{ site.shortName }}{% endif %}</title>
<meta name="description" content="{{ pageDescription }}">
<meta name="author" content="{{ site.name }}">
<meta name="robots" content="{{ metaRobots }}">
<link rel="canonical" href="{{ canonicalUrl }}">

<link rel="icon" href="/assets/icon.svg" type="image/svg+xml">
<link rel="alternate icon" href="/assets/icon.svg">
<link rel="stylesheet" href="/assets/styles.css">

<meta property="og:type" content="{{ ogType }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDescription }}">
<meta property="og:url" content="{{ canonicalUrl }}">
<meta property="og:image" content="{{ ogImageUrl }}">
<meta property="og:image:alt" content="{{ seo.ogImageAlt }}">
<meta property="og:locale" content="{{ seo.locale }}">
{%- if schemaType == 'BlogPosting' %}
<meta property="article:published_time" content="{{ page.date | isoDate }}">
<meta property="article:author" content="{{ site.name }}">
{%- endif %}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ pageDescription }}">
<meta name="twitter:image" content="{{ ogImageUrl }}">
{% if seo.twitterHandle %}<meta name="twitter:creator" content="{{ seo.twitterHandle }}">{% endif %}

{#- JSON-LD: Person (home page only, combined with WebSite) -#}
{%- if schemaType == 'Person' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "{{ site.baseUrl }}/#person",
      "name": "{{ site.name }}",
      "url": "{{ site.baseUrl }}/",
      "jobTitle": "{{ site.role }}",
      "image": "{{ site.baseUrl }}/assets/photo.jpg",
      "affiliation": {
        "@type": "Organization",
        "name": "{{ site.affiliation.name }}",
        "url": "{{ site.affiliation.url }}"
      },
      "sameAs": [
        {%- set links = [] -%}
        {%- if site.identity.orcid and 'UPDATE' not in site.identity.orcid -%}
          {%- set links = (links.push('https://orcid.org/' + site.identity.orcid), links) -%}
        {%- endif -%}
        {%- if site.identity.scholar and 'UPDATE' not in site.identity.scholar -%}
          {%- set links = (links.push(site.identity.scholar), links) -%}
        {%- endif -%}
        {%- if site.identity.linkedin and 'UPDATE' not in site.identity.linkedin -%}
          {%- set links = (links.push(site.identity.linkedin), links) -%}
        {%- endif -%}
        {%- if site.identity.odu and 'UPDATE' not in site.identity.odu -%}
          {%- set links = (links.push(site.identity.odu), links) -%}
        {%- endif -%}
        {%- for link in links -%}"{{ link }}"{%- if not loop.last -%},{%- endif -%}{%- endfor -%}
      ]
    },
    {
      "@type": "WebSite",
      "@id": "{{ site.baseUrl }}/#website",
      "url": "{{ site.baseUrl }}/",
      "name": "{{ site.name }}",
      "description": "{{ seo.defaultDescription }}",
      "publisher": { "@id": "{{ site.baseUrl }}/#person" },
      "inLanguage": "{{ seo.language }}"
    }
  ]
}
</script>
{%- endif %}

{#- JSON-LD: BlogPosting -#}
{%- if schemaType == 'BlogPosting' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ pageTitle | dump | safe }},
  "description": {{ pageDescription | dump | safe }},
  "image": "{{ ogImageUrl }}",
  "datePublished": "{{ page.date | isoDate }}",
  "dateModified": "{{ page.date | isoDate }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.name }}",
    "url": "{{ site.baseUrl }}/"
  },
  "publisher": {
    "@type": "Person",
    "name": "{{ site.name }}",
    "url": "{{ site.baseUrl }}/"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ canonicalUrl }}"
  }
}
</script>
{%- endif %}

{#- JSON-LD: Course (teaching page) -#}
{%- if schemaType == 'Course' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "MPHO 605 — Biostatistics",
  "courseCode": "MPHO 605",
  "description": "Graduate biostatistics course covering hypothesis testing, confidence intervals, categorical data, and applied interpretation for public-health research.",
  "provider": {
    "@type": "Organization",
    "name": "{{ site.affiliation.name }}",
    "url": "{{ site.affiliation.url }}"
  },
  "instructor": {
    "@type": "Person",
    "name": "{{ site.name }}",
    "url": "{{ site.baseUrl }}/"
  },
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "blended"
  },
  "associatedMedia": {
    "@type": "SoftwareApplication",
    "name": "Z-t-Chi Calculator",
    "url": "https://ztchi.hgaladima.com/",
    "applicationCategory": "EducationalApplication",
    "operatingSystem": "Web Browser"
  }
}
</script>
{%- endif %}

{#- JSON-LD: WebPage (fallback for About/CV/Contact) -#}
{%- if schemaType == 'WebPage' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ pageTitle | dump | safe }},
  "description": {{ pageDescription | dump | safe }},
  "url": "{{ canonicalUrl }}",
  "isPartOf": { "@type": "WebSite", "url": "{{ site.baseUrl }}/" },
  "about": { "@type": "Person", "name": "{{ site.name }}" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.baseUrl }}/" },
      { "@type": "ListItem", "position": 2, "name": {{ pageTitle | dump | safe }}, "item": "{{ canonicalUrl }}" }
    ]
  }
}
</script>
{%- endif %}

{#- JSON-LD: CollectionPage (research/blog index) -#}
{%- if schemaType == 'CollectionPage' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ pageTitle | dump | safe }},
  "description": {{ pageDescription | dump | safe }},
  "url": "{{ canonicalUrl }}",
  "isPartOf": { "@type": "WebSite", "url": "{{ site.baseUrl }}/" },
  "about": { "@type": "Person", "name": "{{ site.name }}" }
}
</script>
{%- endif %}
