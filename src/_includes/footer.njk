<footer class="site-footer">
  <div class="site-footer-inner">
    <p class="site-footer-identity">
      &copy; {{ site.buildYear }} {{ site.name }}. All rights reserved.
    </p>
    <nav aria-label="Related sites" class="site-footer-nav">
      <p class="site-footer-nav-title">Related</p>
      <ul>
        {% for link in site.related %}
          <li><a href="{{ link.href }}" rel="me">{{ link.label }}</a></li>
        {% endfor %}
        <li><a href="/contact/">Contact</a></li>
      </ul>
    </nav>
  </div>
</footer>
