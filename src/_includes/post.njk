---
layout: base.njk
schemaType: BlogPosting
---
<article class="post">
  <header class="post-header">
    <p class="post-kicker">Blog</p>
    <h1 class="post-title">{{ title }}</h1>
    <p class="post-meta">
      <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time>
      {% if tags and tags.length %}
        &middot;
        <span class="post-tags">
          {% for tag in tags %}<span class="post-tag">#{{ tag }}</span>{% if not loop.last %} {% endif %}{% endfor %}
        </span>
      {% endif %}
    </p>
    {% if summary %}<p class="post-summary">{{ summary }}</p>{% endif %}
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <p><a href="/blog/">&larr; Back to all posts</a></p>
  </footer>
</article>
