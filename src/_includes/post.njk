---
layout: base.njk
schemaType: BlogPosting
---
<article class="post">
  <header class="post-header reveal">
    <p class="post-kicker">Blog</p>
    <h1 class="post-title">{{ title }}</h1>
    <p class="post-meta">
      <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time>
      {% if tags and tags.length %}
        <span aria-hidden="true">·</span>
        {% for tag in tags %}<span class="post-tag">#{{ tag }}</span>{% endfor %}
      {% endif %}
    </p>
    {% if summary %}<p class="post-summary">{{ summary }}</p>{% endif %}
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <p><a href="/blog/">&larr; All posts</a></p>
  </footer>
</article>
